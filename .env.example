# ─── API Keys ──────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Optional: custom voice ID from ElevenLabs (default: "Adam" professional male voice)
ELEVENLABS_VOICE_ID=

# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-key-here

# ─── Google Service Account ────────────────────────────────
# Path to your service-account JSON file
GOOGLE_CREDENTIALS_JSON=google-credentials.json

# Your YouTube Channel ID (for upload targeting)
YOUTUBE_CHANNEL_ID=

# Google Drive folder ID where videos will be saved
# (leave empty to upload to root "My Drive")
DRIVE_FOLDER_ID=
